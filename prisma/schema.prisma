generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model StoreSetting {
  id              Int      @id
  storeName       String
  heroTitle       String
  heroSubtitle    String   @db.Text
  heroNotice      String   @default("") @db.Text
  supportEmail    String   @default("")
  supportPhone    String   @default("")
  purchaseGuide   String   @default("") @db.Text
  orderLink       String   @default("") @db.Text
  paymentAccountName   String   @default("")
  paymentAccountNumber String   @default("")
  paymentBankName      String   @default("")
  updatedAt       DateTime @updatedAt

  i18n            StoreSettingI18n[]
}

model StoreSettingI18n {
  storeId       Int
  locale        String
  heroTitle     String
  heroSubtitle  String   @db.Text
  heroNotice    String   @default("") @db.Text
  purchaseGuide String   @default("") @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         StoreSetting @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([storeId, locale])
  @@index([locale])
}

model Category {
  id          String    @id
  name        String
  slug        String?   @unique
  description String
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model FilterGroup {
  id          String         @id
  name        String
  slug        String?        @unique
  description String         @default("")
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  options     FilterOption[]
}

model FilterOption {
  id          String               @id
  groupId     String
  label       String
  value       String
  sortOrder   Int                  @default(0)
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  group       FilterGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productRefs ProductFilterOption[]

  @@index([groupId])
}

model Product {
  id            String               @id
  name          String
  slug          String?
  sku           String?
  brand         String               @default("")
  categoryId    String
  price         Decimal              @default(0) @db.Decimal(10, 2)
  originalPrice Decimal?             @db.Decimal(10, 2)
  badge         String?
  inventory     Int                  @default(0)
  description   String               @db.Text
  imageUrl      String               @default("") @db.Text
  sizes         String               @default("") @db.Text
  colorway      String               @default("")
  featured      Boolean              @default(false)
  status        String               @default("ACTIVE")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  category      Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  filterRefs    ProductFilterOption[]
  orderItems    OrderItem[]

  @@index([categoryId])
}

model ProductFilterOption {
  productId String
  optionId  String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  option    FilterOption @relation(fields: [optionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([productId, optionId])
  @@index([optionId])
}

model CustomerUser {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  passwordHash String
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sessions     CustomerSession[]
  orders       Order[]
}

model CustomerSession {
  id         String       @id
  token      String       @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  user       CustomerUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Order {
  id              String       @id @default(cuid())
  userId          String
  status          String       @default("PENDING")
  totalAmount     Float
  receiverName    String
  receiverPhone   String
  receiverEmail   String
  receiverAddress String       @db.Text
  note            String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            CustomerUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]

  @@index([userId, createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  productName  String
  productPrice Float
  quantity     Int
  lineTotal    Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId, createdAt])
  @@index([productId])
}

model AdminUser {
  id           String         @id
  username     String         @unique
  displayName  String
  email        String?
  passwordHash String
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id         String    @id
  token      String    @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
